PORT=5000
# If you still see retryable-writes errors, append: ?retryWrites=false
MONGO_URI=mongodb://127.0.0.1:27017/campusflow_ai
JWT_SECRET=replace_with_strong_secret
GEMINI_API_KEY=replace_with_gemini_api_key
# Optional override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Email — use NO spaces around = and NO quotes (or our mailer will strip quotes).
# Gmail: enable 2-Step Verification → Google Account → App passwords → generate 16-char app password.
# Put the app password in SMTP_PASS (spaces optional; they are removed automatically).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Optional: use instead of guessing from host
# SMTP_SERVICE=gmail
EMAIL_FROM=you@gmail.com
